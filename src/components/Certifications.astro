---
import { certifications } from '../data/certifications';
const cert = certifications[0];
---

<div class="panel panel-cert" data-reveal>
  <div class="cert-big">{cert.issuer}</div>
  <div class="cert-title">{cert.title}</div>
  <p class="cert-detail">
    Professional Certificate · {cert.totalCourses} courses completed via {cert.platform}.
    Covers Docker, Kubernetes, CI/CD, Cloud Computing, Security & more.
  </p>
  <a href={cert.url} target="_blank" rel="noopener noreferrer" class="cert-badge">
    ✦ VERIFIED · {cert.completedDate.toUpperCase()} · VIEW CREDENTIAL →
  </a>
</div>

<style>
  .panel-cert {
    padding: 36px;
    border-color: rgba(255, 213, 79, 0.12);
    background: linear-gradient(135deg, rgba(255, 213, 79, 0.04), transparent);
  }
  .cert-big {
    font-size: 3.25rem;
    font-weight: 800;
    color: var(--gold);
    text-shadow: 0 0 30px var(--gold-glow);
    line-height: 1;
    margin-bottom: 8px;
  }
  .cert-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 12px;
    line-height: 1.3;
  }
  .cert-detail {
    font-size: 0.8125rem;
    color: var(--muted);
    line-height: 1.7;
  }
  .cert-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 20px;
    font-size: 0.5625rem;
    color: var(--gold);
    letter-spacing: 0.12em;
    padding: 7px 14px;
    border: 1px solid rgba(255, 213, 79, 0.25);
    border-radius: 2px;
    background: rgba(255, 213, 79, 0.06);
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease, letter-spacing 0.3s ease;
    cursor: pointer;
  }
  .cert-badge:hover {
    background: rgba(255, 213, 79, 0.12);
    border-color: rgba(255, 213, 79, 0.5);
    letter-spacing: 0.15em;
  }
</style>
