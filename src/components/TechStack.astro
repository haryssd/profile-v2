---
import { skills } from '../data/skills';
---

<div class="skills-cloud">
  {skills.map((skill, i) => (
    <span
      class="skill-tag"
      data-category={skill.category}
      style={`animation-delay:${i * 40}ms`}
    >
      {skill.name}
    </span>
  ))}
</div>

<style>
  .skills-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  @keyframes tag-in {
    from { opacity: 0; transform: translateY(8px) scale(0.95); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .skill-tag {
    font-size: 0.875rem;
    color: var(--muted);
    padding: 10px 18px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 2px;
    letter-spacing: 0.04em;
    transition: color 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease, transform 0.25s var(--ease-spring);
    cursor: default;
    opacity: 0;
    animation: tag-in 0.45s var(--ease-out) forwards;
    animation-play-state: paused;
  }

  /* Tags animate when parent panel enters view */
  .panel.revealed .skill-tag,
  .revealed .skill-tag {
    animation-play-state: running;
  }

  .skill-tag:hover {
    color: var(--text);
    border-color: rgba(255, 213, 79, 0.3);
    background: var(--gold-dim);
    box-shadow: 0 0 16px rgba(255, 213, 79, 0.1);
    transform: translateY(-2px) scale(1.03);
  }
</style>
