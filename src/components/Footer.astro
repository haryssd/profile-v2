---
import { profile } from '../data/profile';
const year = new Date().getFullYear();
---

<footer>
  <span class="footer-copy">
    © {year} {profile.name.full.toUpperCase()} · ALL SYSTEMS NOMINAL
  </span>
  <div class="footer-stack">
    <span class="stack-badge">Astro</span>
    <span class="stack-badge">Cloudflare</span>
    <span class="stack-badge">Docker</span>
  </div>
</footer>

<style>
  footer {
    max-width: 1200px;
    margin: 0 auto;
    padding: 28px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--border);
  }
  .footer-copy {
    font-size: 0.625rem;
    color: rgba(255,255,255,0.2);
    letter-spacing: 0.08em;
  }
  .footer-stack { display: flex; gap: 8px; }
  .stack-badge {
    font-size: 0.5625rem;
    color: rgba(255,213,79,0.3);
    border: 1px solid rgba(255,213,79,0.1);
    padding: 4px 10px;
    border-radius: 2px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    footer { padding: 24px; flex-direction: column; gap: 12px; text-align: center; }
  }
</style>
