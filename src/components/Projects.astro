---
import { projects } from '../data/projects';
---

<section id="projects" class="section-wrapper">
  <p class="section-label" data-reveal>// projects</p>
  <h2 class="projects-heading" data-reveal data-delay="80">Things I've <span class="gold-italic">built.</span></h2>
  <div class="projects-grid">
    {projects.map((project, i) => (
      <div class="panel panel-project" data-reveal="scale" data-delay={String(i * 120)}>
        <div class="proj-num">{project.num} · {project.category.toUpperCase()}</div>
        <h3 class="proj-title">{project.title}</h3>
        <p class="proj-desc">{project.description}</p>
        <div class="proj-tags">
          {project.tags.map((tag) => (
            <span class="tl-tag">{tag}</span>
          ))}
        </div>
        <div class="proj-footer">
          {project.url ? (
            <a href={project.url} target="_blank" rel="noopener noreferrer" class="proj-link">
              Observe →
            </a>
          ) : (
            <span class="proj-private">Private · Internal</span>
          )}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .section-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 48px;
  }

  .projects-heading {
    font-size: clamp(32px, 3.5vw, 48px);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin-bottom: 36px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  /* Single card: don't stretch full width */
  .projects-grid:has(.panel-project:only-child) {
    grid-template-columns: minmax(0, 380px);
  }

  .panel-project {
    padding: 30px 26px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition:
      border-color 0.35s ease,
      box-shadow 0.35s ease,
      transform 0.35s var(--ease-spring) !important;
  }

  /* Gold sweep on hover */
  .panel-project::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top left, rgba(255,213,79,0.07), transparent 65%);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
  .panel-project:hover::after { opacity: 1; }
  .panel-project:hover {
    transform: translateY(-6px) !important;
    box-shadow: 0 16px 48px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,213,79,0.15) !important;
  }

  .proj-num {
    font-size: 0.5625rem;
    color: rgba(255,213,79,0.35);
    letter-spacing: 0.2em;
    margin-bottom: 16px;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }
  .panel-project:hover .proj-num { color: rgba(255,213,79,0.65); }

  .proj-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 10px;
    letter-spacing: -0.01em;
    line-height: 1.2;
    transition: color 0.2s ease;
  }
  .panel-project:hover .proj-title { color: var(--gold); }

  .proj-desc {
    font-size: 0.8125rem;
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 20px;
    flex: 1;
  }

  .proj-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 20px;
  }

  .proj-footer { margin-top: auto; }

  .proj-link {
    font-size: 0.625rem;
    color: var(--gold);
    text-decoration: none;
    letter-spacing: 0.1em;
    opacity: 0.55;
    transition: opacity 0.2s ease, letter-spacing 0.3s ease;
    text-transform: uppercase;
  }
  .proj-link:hover {
    opacity: 1;
    letter-spacing: 0.15em;
  }

  .proj-private {
    font-size: 0.5625rem;
    color: var(--muted);
    letter-spacing: 0.1em;
    opacity: 0.4;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .projects-grid { grid-template-columns: 1fr; }
    .section-wrapper { padding: 0 24px; }
    .panel-project:hover { transform: none !important; }
  }
</style>
