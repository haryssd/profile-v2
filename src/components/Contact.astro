---
import { profile } from '../data/profile';
---

<section id="contact" class="section-wrapper">
  <div class="panel panel-contact" data-reveal="scale">
    <p class="section-label">// initiate contact</p>
    <h2 class="contact-heading">
      Transmit a<br /><span class="gold-italic">Signal.</span>
    </h2>
    <p class="contact-sub">
      Open to new opportunities, collaborations, or just a conversation about space, mountains, and good software.
    </p>
    <div class="contact-links">
      <a href={`mailto:${profile.contact.email}`} class="btn-gold">
        {profile.contact.email} →
      </a>
      <a href={profile.socials.github} target="_blank" rel="noopener noreferrer" class="btn-ghost">
        GitHub
      </a>
      <a href={profile.socials.linkedin} target="_blank" rel="noopener noreferrer" class="btn-ghost">
        LinkedIn
      </a>
      <a href={profile.socials.instagram} target="_blank" rel="noopener noreferrer" class="btn-ghost">
        Instagram
      </a>
    </div>
  </div>
</section>

<style>
  .section-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 48px;
  }

  .panel-contact {
    padding: 80px 60px;
    text-align: center;
    background: linear-gradient(135deg, rgba(255,213,79,0.03), transparent 60%);
    border-color: rgba(255,213,79,0.08);
  }

  .contact-heading {
    font-size: clamp(56px, 9vw, 112px);
    font-weight: 300;
    line-height: 0.92;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }

  .contact-sub {
    font-size: 0.9375rem;
    color: var(--muted);
    margin-bottom: 48px;
    max-width: 440px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
  }

  .contact-links {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .section-wrapper { padding: 0 24px; }
    .panel-contact { padding: 48px 24px; }
  }
</style>
