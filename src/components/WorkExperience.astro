---
import { experience } from '../data/experience';
---

<section id="work" class="section-wrapper">
  <div class="panel panel-work" data-reveal>
    <p class="section-label">// experience</p>
    <h2 class="work-heading">
      Where I've been <span class="gold-italic">building.</span>
    </h2>
    <div class="timeline">
      {experience.map((job, i) => (
        <div class="tl-item" data-reveal data-delay={String(i * 100)}>
          <div class="tl-date">
            {job.start} — {job.end}
            <span class="tl-elapsed">{job.elapsed}</span>
          </div>
          <div class="tl-line">
            <div class="tl-dot"></div>
          </div>
          <div class="tl-content">
            <div class="tl-role">{job.role}</div>
            <div class="tl-company">{job.company} · {job.location}</div>
            <p class="tl-desc">{job.description}</p>
            <div class="tl-tags">
              {job.tags.map((tag) => (
                <span class="tl-tag">{tag}</span>
              ))}
            </div>

            {job.systems.length > 0 && (
              <div class="systems-grid">
                {job.systems.map((sys) => (
                  <div class="system-card">
                    <div class="system-header">
                      <span class="system-name">{sys.name}</span>
                      <span class="system-category">{sys.category}</span>
                    </div>
                    <p class="system-desc">{sys.description}</p>
                    <div class="system-tags">
                      {sys.tags.map((tag) => (
                        <span class="tl-tag">{tag}</span>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 48px;
  }

  .panel-work { padding: 48px 44px; }

  .work-heading {
    font-size: clamp(32px, 3.5vw, 48px);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin-bottom: 40px;
  }

  .timeline { display: flex; flex-direction: column; }

  .tl-item {
    display: grid;
    grid-template-columns: 200px 1px 1fr;
    gap: 32px;
    padding: 32px 16px;
    border-bottom: 1px solid var(--border);
    align-items: start;
    border-radius: 4px;
    transition: background 0.3s ease, transform 0.3s var(--ease-out);
    cursor: default;
  }
  .tl-item:last-child { border-bottom: none; }
  .tl-item:hover {
    background: rgba(255,255,255,0.015);
    transform: translateX(4px);
  }

  .tl-date {
    font-size: 0.625rem;
    color: rgba(255, 213, 79, 0.45);
    letter-spacing: 0.1em;
    line-height: 1.6;
    padding-top: 4px;
  }
  .tl-elapsed {
    display: block;
    color: var(--muted);
    margin-top: 4px;
    opacity: 0.5;
    font-size: 0.5625rem;
  }

  .tl-line {
    background: linear-gradient(to bottom, rgba(255,213,79,0.4), rgba(255,213,79,0.05));
    position: relative;
    margin-top: 4px;
    transition: background 0.3s ease;
  }
  .tl-item:hover .tl-line {
    background: linear-gradient(to bottom, rgba(255,213,79,0.7), rgba(255,213,79,0.1));
  }
  .tl-dot {
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--gold);
    box-shadow: 0 0 10px var(--gold), 0 0 20px rgba(255,213,79,0.4);
    border: 1px solid var(--space);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  .tl-item:hover .tl-dot {
    box-shadow: 0 0 16px var(--gold), 0 0 32px rgba(255,213,79,0.5);
    transform: translateX(-50%) scale(1.3);
  }

  .tl-role {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 4px;
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
  }
  .tl-item:hover .tl-role { color: var(--gold); }

  .tl-company {
    font-size: 0.625rem;
    color: var(--gold);
    letter-spacing: 0.1em;
    opacity: 0.7;
    text-transform: uppercase;
    margin-bottom: 12px;
    transition: opacity 0.2s ease;
  }
  .tl-item:hover .tl-company { opacity: 1; }

  .tl-desc {
    font-size: 0.8125rem;
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 14px;
  }

  .tl-tags { display: flex; flex-wrap: wrap; gap: 6px; }

  /* Systems grid */
  .systems-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
    margin-top: 20px;
  }

  .system-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 3px;
    padding: 14px 16px;
    transition: border-color 0.25s ease, background 0.25s ease, transform 0.25s var(--ease-spring);
  }
  .system-card:hover {
    border-color: rgba(255,213,79,0.2);
    background: rgba(255,213,79,0.03);
    transform: translateY(-2px);
  }

  .system-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
    gap: 8px;
  }
  .system-name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
  }
  .system-category {
    font-size: 0.5rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,213,79,0.5);
    border: 1px solid rgba(255,213,79,0.15);
    padding: 2px 7px;
    border-radius: 2px;
    white-space: nowrap;
  }
  .system-desc {
    font-size: 0.75rem;
    color: var(--muted);
    line-height: 1.65;
    margin-bottom: 10px;
  }
  .system-tags { display: flex; flex-wrap: wrap; gap: 5px; }

  @media (max-width: 900px) {
    .systems-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .section-wrapper { padding: 0 24px; }
    .panel-work { padding: 32px 24px; }
    .tl-item { grid-template-columns: 1px 1fr; gap: 20px; }
    .tl-date { display: none; }
    .tl-item:hover { transform: none; }
  }
</style>
