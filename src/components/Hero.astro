---
import { profile } from '../data/profile';
---

<section id="hero">
  <div class="hero-inner">
    <!-- Left: Text -->
    <div class="hero-text">
      <div class="hero-eyebrow hero-anim" style="animation-delay:0.1s">{profile.role}
        <span class="dash"></span>
      </div>

      <h1 class="hero-name hero-anim" style="animation-delay:0.25s">
        {profile.name.first}<br />
        <span class="gold-stroke">{profile.name.last}</span><span class="gold-dot">.</span>
      </h1>

      <p class="hero-tagline hero-anim" style="animation-delay:0.4s">
        {profile.tagline}<span class="cursor">_</span>
      </p>

      <div class="hero-actions hero-anim" style="animation-delay:0.55s">
        <a href="#work" class="btn-gold">Explore Work</a>
        <a href="#contact" class="btn-ghost">Initiate Contact</a>
      </div>

      <div class="hero-coords hero-anim" style="animation-delay:0.7s">
        COORD · {profile.location.coordinates.lat} {profile.location.coordinates.lng} · {profile.location.city.toUpperCase()} · {profile.location.flag}
      </div>
    </div>

    <!-- Right: Profile photo -->
    <div class="hero-photo-wrap hero-anim" style="animation-delay:0.5s">
      <div class="hero-photo-frame">
        <img
          src="/images/profile.webp"
          alt={profile.name.full}
          class="hero-photo"
          loading="eager"
          decoding="async"
        />
        <div class="hero-photo-glow"></div>
      </div>
    </div>
  </div>

  <div class="hero-status hero-anim" style="animation-delay:0.85s">
    <div class="pulsar">
      <div class="pulsar-dot"></div>
      <div class="pulsar-dot"></div>
      <div class="pulsar-dot"></div>
    </div>
    {profile.availability.status}
  </div>
</section>

<style>
  #hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 120px 56px 80px;
    position: relative;
  }

  .hero-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 48px;
    width: 100%;
    max-width: 1200px;
  }

  .hero-text {
    flex: 1;
    min-width: 0;
  }

  /* Photo */
  .hero-photo-wrap {
    flex-shrink: 0;
    position: relative;
    opacity: 0;
  }

  .hero-photo-frame {
    position: relative;
    width: 300px;
    height: 380px;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid rgba(255, 213, 79, 0.15);
    box-shadow:
      0 0 0 1px rgba(255,213,79,0.05),
      0 32px 80px rgba(0,0,0,0.6),
      0 0 60px rgba(255,213,79,0.04);
  }

  .hero-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    filter: brightness(0.92) contrast(1.05);
    transition: filter 0.4s ease, transform 0.5s var(--ease-spring);
  }
  .hero-photo-frame:hover .hero-photo {
    filter: brightness(1) contrast(1.05);
    transform: scale(1.03);
  }

  /* Subtle gold overlay */
  .hero-photo-glow {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, rgba(255,213,79,0.06) 0%, transparent 40%),
      linear-gradient(to bottom, rgba(0,0,5,0.3) 0%, transparent 30%);
    pointer-events: none;
  }

  /* Floating availability tag */
  .hero-photo-tag {
    position: absolute;
    bottom: -14px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(5, 5, 20, 0.9);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 999px;
    padding: 6px 14px;
    font-size: 0.5625rem;
    color: var(--muted);
    letter-spacing: 0.08em;
    white-space: nowrap;
    backdrop-filter: blur(8px);
  }

  /* Entrance animation */
  @keyframes hero-fade-up {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .hero-anim {
    opacity: 0;
    animation: hero-fade-up 0.7s var(--ease-out) forwards;
  }

  .hero-eyebrow {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--gold);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 14px;
    opacity: 0;
  }
  .dash {
    width: 40px; height: 1px;
    background: linear-gradient(to right, var(--gold), transparent);
    opacity: 0.6;
  }

  .hero-name {
    font-size: clamp(72px, 11vw, 160px);
    font-weight: 300;
    line-height: 0.92;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
    color: var(--text);
  }
  .gold-stroke {
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 213, 79, 0.6);
    font-style: italic;
    transition: -webkit-text-stroke-color 0.3s ease;
  }
  .gold-stroke:hover {
    -webkit-text-stroke-color: rgba(255, 213, 79, 1);
  }
  .gold-dot {
    color: var(--gold);
    text-shadow: 0 0 60px rgba(255,213,79,0.3), 0 0 120px rgba(255,213,79,0.1);
  }

  .hero-tagline {
    font-size: 0.8125rem;
    color: var(--muted);
    letter-spacing: 0.1em;
    margin-bottom: 48px;
  }
  .cursor {
    color: var(--gold);
    animation: blink 1.2s step-end infinite;
  }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  .hero-actions {
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
  }

  .hero-coords {
    font-size: 0.625rem;
    color: rgba(255, 213, 79, 0.3);
    letter-spacing: 0.1em;
    margin-top: 56px;
    transition: color 0.3s ease;
  }
  .hero-coords:hover { color: rgba(255, 213, 79, 0.55); }

  .hero-status {
    position: absolute;
    bottom: 48px;
    right: 56px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.625rem;
    color: var(--muted);
    letter-spacing: 0.08em;
  }
  .pulsar { display: flex; gap: 3px; align-items: center; }
  .pulsar-dot {
    width: 5px; height: 5px;
    background: #4ade80;
    border-radius: 50%;
    box-shadow: 0 0 8px #4ade80;
  }

  @media (max-width: 900px) {
    .hero-photo-wrap { display: none; }
  }

  @media (max-width: 768px) {
    #hero { padding: 100px 24px 80px; }
    .hero-status { right: 24px; bottom: 24px; }
    .hero-inner { gap: 32px; }
  }
</style>
