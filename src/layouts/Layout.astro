---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Haris Daniel Noh — Full-Stack Software Engineer',
  description = 'Haris Daniel Noh is a Full-Stack Software Engineer based in Kuala Lumpur, Malaysia. Specialising in Vue.js, .NET, Node.js, Docker, and cloud infrastructure.',
} = Astro.props;

const siteUrl = 'https://harisdanielnoh-dev.pages.dev';
const ogImage = `${siteUrl}/images/profile.webp`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Haris Daniel Noh" />
    <meta name="keywords" content="Haris Daniel Noh, harisdanielnoh, Full-Stack Software Engineer, Vue.js, .NET, Node.js, Kuala Lumpur, Malaysia, Software Developer" />
    <link rel="canonical" href={siteUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_MY" />
    <meta property="og:site_name" content="Haris Daniel Noh" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD Person Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Haris Daniel Noh",
      "alternateName": "Haris Daniel",
      "url": siteUrl,
      "image": ogImage,
      "jobTitle": "Full-Stack Software Engineer",
      "worksFor": {
        "@type": "Organization",
        "name": "CIBC Technology Sdn Bhd"
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Kuala Lumpur",
        "addressCountry": "MY"
      },
      "sameAs": [
        "https://github.com/haryssd",
        "https://www.linkedin.com/in/harisdanielnoh/",
        "https://www.instagram.com/haryssd/"
      ],
      "knowsAbout": ["Vue.js", "Node.js", ".NET", "Docker", "Firebase", "Alibaba Cloud", "MySQL", "TypeScript"]
    })} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <!-- Scroll progress bar -->
    <div id="scroll-progress"></div>

    <slot />
  </body>
</html>

<script>
  // ── Scroll progress bar ───────────────────────────
  const bar = document.getElementById('scroll-progress');
  function updateProgress() {
    const scrolled = window.scrollY;
    const total = document.documentElement.scrollHeight - window.innerHeight;
    const pct = total > 0 ? (scrolled / total) * 100 : 0;
    if (bar) bar.style.width = pct + '%';
  }

  // ── Scroll reveal (Intersection Observer) ─────────
  const revealEls = document.querySelectorAll('[data-reveal]');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          // Respect stagger delay set via data-delay attribute
          const delay = (entry.target as HTMLElement).dataset.delay ?? '0';
          setTimeout(() => {
            entry.target.classList.add('revealed');
          }, parseInt(delay));
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
  );
  revealEls.forEach((el) => observer.observe(el));

  // ── Nav: shrink + blur on scroll ──────────────────
  const nav = document.getElementById('nav');
  function updateNav() {
    if (nav) {
      nav.classList.toggle('nav-scrolled', window.scrollY > 60);
    }
  }

  let rafPending = false;
  window.addEventListener('scroll', () => {
    if (rafPending) return;
    rafPending = true;
    requestAnimationFrame(() => {
      updateProgress();
      updateNav();
      rafPending = false;
    });
  }, { passive: true });

  updateProgress();
  updateNav();
</script>
